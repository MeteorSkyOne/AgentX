    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "katex": "^0.16.45",
    "lucide-react": "^1.11.0",
    "monaco-editor": "^0.55.1",
    "postcss": "^8.5.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.9",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
